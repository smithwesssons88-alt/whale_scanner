# ──────────────────────────────────────────
#  🐋 Whale Parser — змінні середовища
#  Скопіюй цей файл у .env і заповни значення
# ──────────────────────────────────────────

# 1. Telegram Bot Token — від @BotFather
TELEGRAM_BOT_TOKEN=8756979093:AAGRXJA0FF1wTK3pTrC8OboVhqmHrcF_Kco

# 2. Telegram Chat ID
#    https://api.telegram.org/bot<TOKEN>/getUpdates → "chat":{"id":...}
TELEGRAM_CHAT_ID=390975602

# 3. Мінімальна сума ETH для алерту
MIN_ETH_THRESHOLD=5

# 4. Alchemy RPC URL — для скорингу гаманців (баланс + tx_count)
#    Dashboard → Apps → твій app → API Key → HTTPS endpoint
ALCHEMY_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/OlNADHjyHgQ5E9j3KIQBp

# 5. Мінімальний скор для кандидатів копітрейдингу (0-100)
COPYTRADE_MIN_SCORE=50

# 6. Шлях до SQLite бази
DB_PATH=whales.db

# 7. Порт (Railway/Render встановлюють автоматично)
PORT=5000
